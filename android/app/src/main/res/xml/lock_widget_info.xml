<?xml version="1.0" encoding="utf-8"?>
<!--
  AppWidgetProviderInfo — "Günün Kilit Ekranı Kodu" widget'ının boyut/güncelleme
  meta verisi. home_widget dokümantasyonundaki standart kuruluma göre.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="86400000"
    android:initialLayout="@layout/lock_widget_layout"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/lock_widget_description">
</appwidget-provider>
