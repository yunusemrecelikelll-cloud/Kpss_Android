<?xml version="1.0" encoding="utf-8"?>
<!--
  "Günün Kilit Ekranı Kodu" ana ekran widget'ı için layout.
  home_widget paketi ile Flutter tarafından yazılan veriler
  (LockWidgetService.keyEyebrow / keyText) burada gösterilir.
  Bkz: android/app/src/main/kotlin/.../LockWidgetProvider.kt
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/lock_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:padding="14dp"
    android:orientation="vertical"
    android:background="@drawable/lock_widget_background">

    <TextView
        android:id="@+id/lock_widget_head"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔒 Günün Kilit Ekranı Kodu"
        android:textColor="#C9A227"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lock_widget_eyebrow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#9A93A8"
        android:textSize="11sp"
        tools:text="Türkçe • Ses Bilgisi" />

    <TextView
        android:id="@+id/lock_widget_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="4"
        android:textColor="#F2EEF7"
        android:textSize="14sp"
        tools:text="Büyük ünlü uyumu: kelimenin ilk hecesindeki ünlü kalınsa sonraki hecelerdeki ünlüler de kalın olur." />
</LinearLayout>
